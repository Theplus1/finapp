{
  "name": "finapp",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:admin": "turbo run build --filter=admin-web",
    "build:customer": "turbo run build --filter=customer-web",
    "build:server": "turbo run build --filter=server",
    "dev": "turbo run dev",
    "dev:admin": "turbo run dev --filter=admin-web",
    "dev:customer": "turbo run dev --filter=customer-web",
    "dev:server": "turbo run dev --filter=server",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test:server": "turbo run test --filter=server",
    "test:e2e": "turbo run test:e2e --filter=server"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "turbo": "^2.5.8",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/websockets": "^10.4.22",
    "@opentelemetry/context-async-hooks": "^2.2.0",
    "@opentelemetry/core": "^2.2.0",
    "@opentelemetry/sdk-trace-base": "^2.2.0",
    "next": "^15.5.7",
    "socket.io": "^4.8.3"
  },
  "overrides": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0"
  }
}
